# ── Classify client ───────────────────────────────────────────────────────────
# docker build -f Dockerfile.client -t depression_vllm_client .
FROM python:3.12-slim

RUN pip install --no-cache-dir pandas tqdm openai

WORKDIR /app
COPY classify_vllm.py /app/classify_vllm.py

ENV INPUT_CSV=/data/test.csv \
    OUTPUT_CSV=/data/output.csv \
    VLLM_BASE_URL=http://localhost:8000/v1

ENTRYPOINT ["python3", "/app/classify_vllm.py"]